{
  "name": "private-mens-health-coach",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first mobile men's health coach MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "smoke:web": "playwright test e2e/web-smoke.spec.ts",
    "mobile": "npm --workspace @pmhc/mobile run start",
    "api": "npm --workspace @pmhc/api run dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
